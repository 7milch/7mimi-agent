# syntax=docker/dockerfile:1
FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# git: needed by scheduler-side helpers that shell out to git (clone-back
# verification etc., ADR-021). docker-cli: the scheduler launches agent-runner
# as a sibling container via the mounted host /var/run/docker.sock (ADR-024);
# it only needs the `docker` CLI binary, not a Docker daemon of its own.
#
# Debian slim's `docker.io` package pulls in the full daemon/containerd stack
# (~200MB) just to get the CLI. Instead we install the statically linked
# `docker` CLI-only tarball from Docker's official download server (no
# daemon, no containerd, no extra apt sources) and discard everything except
# the `docker` binary itself.
# Docker does not publish a .sha256 file alongside this tarball, so the
# checksums below were computed by hand (sha256sum) against the exact
# download URLs on 2026-07-05 and are pinned here; bump both together with
# DOCKER_CLI_VERSION when upgrading.
ARG DOCKER_CLI_VERSION=27.3.1
ARG DOCKER_CLI_SHA256_AMD64=9b4f6fe406e50f9085ee474c451e2bb5adb119a03591f467922d3b4e2ddf31d3
ARG DOCKER_CLI_SHA256_ARM64=4da6a6c7502b7ab561675a5ff5ac192d9b49d76d0b8847cf17ade246122279f4
RUN apt-get update \
 && apt-get install -y --no-install-recommends git ca-certificates curl \
 && ARCH="$(dpkg --print-architecture)" \
 && case "$ARCH" in \
      amd64) DOCKER_ARCH=x86_64; DOCKER_CLI_SHA256="$DOCKER_CLI_SHA256_AMD64" ;; \
      arm64) DOCKER_ARCH=aarch64; DOCKER_CLI_SHA256="$DOCKER_CLI_SHA256_ARM64" ;; \
      *) echo "unsupported architecture: $ARCH" >&2; exit 1 ;; \
    esac \
 && curl -fsSL "https://download.docker.com/linux/static/stable/${DOCKER_ARCH}/docker-${DOCKER_CLI_VERSION}.tgz" -o /tmp/docker-cli.tgz \
 && echo "${DOCKER_CLI_SHA256}  /tmp/docker-cli.tgz" | sha256sum -c - \
 && tar -xzf /tmp/docker-cli.tgz -C /tmp \
 && install -m 0755 /tmp/docker/docker /usr/local/bin/docker \
 && rm -rf /tmp/docker-cli.tgz /tmp/docker \
 && apt-get purge -y curl \
 && apt-get autoremove -y \
 && apt-get clean && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md ./
COPY src ./src

RUN pip install --upgrade pip \
 && pip install -e .

# Runtime mounts the repository at an identical absolute path on host and
# container (see docker-compose.yml) so that the scheduler's own
# `docker run -v <path>` invocations for sibling agent-runner containers
# resolve correctly on the host Docker daemon.
WORKDIR /workspace

ENTRYPOINT []
CMD ["python", "-m", "shichimimi_agent", "schedule", "run"]
