# syntax=docker/dockerfile:1
FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# Claude Code CLI (ADR-013). It talks to claude-proxy via ANTHROPIC_BASE_URL /
# ANTHROPIC_AUTH_TOKEN; this container never receives ANTHROPIC_API_KEY.
RUN apt-get update \
 && apt-get install -y --no-install-recommends nodejs npm git ca-certificates ripgrep \
 && npm install -g @anthropic-ai/claude-code \
 && apt-get clean && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md ./
COPY src ./src

RUN pip install --upgrade pip \
 && pip install -e .

# Runtime normally mounts the project repository at /workspace and runs there.
WORKDIR /workspace

ENTRYPOINT []
CMD ["python", "-m", "sevenmimi_agent", "config", "validate"]
