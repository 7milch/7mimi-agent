# Keep real secrets out of agent-runner containers.
# claude-proxy owns Claude provider credentials. auth-proxy / MCP servers own external API credentials.

# X API / XMCP
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_API_TOOL_ALLOWLIST=searchPostsRecent,getPosts,getUsers,getUsersByUsername

# J-Quants MCP
JQUANTS_API_KEY=

# Claude proxy
# ANTHROPIC_API_KEY is for claude-proxy only. Do not mount it into agent-runner containers.
CLAUDE_PROXY_URL=http://localhost:18080
CLAUDE_PROXY_SECRET_DIR=.secrets/claude
CLAUDE_PROXY_SESSION_TOKEN_TTL_SECONDS=3600

# Claude provider credential for claude-proxy only. Do not mount into agent-runner containers.
ANTHROPIC_API_KEY=
