# Keep real secrets out of agent-runner containers.
# MCP servers or credential brokers should read these, not the LLM agent itself.

# X API / XMCP
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_API_TOOL_ALLOWLIST=searchPostsRecent,getPosts,getUsers,getUsersByUsername

# J-Quants MCP
JQUANTS_API_KEY=

# LLM provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
